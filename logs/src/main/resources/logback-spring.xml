<configuration debug="true">
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />
    <springProperty scope="context" name="rabbitMQHost" source="spring.rabbitmq.host"/>
    <springProperty scope="context" name="rmq.user" source="spring.rabbitmq.username" defaultValue="guest"/>
    <springProperty scope="context" name="rmq.pass" source="spring.rabbitmq.password" defaultValue="pshankar26"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>
<!--                [%-15marker] %highlight(%-5level) %msg%n-->
                [%-15marker] [%X{X-B3-TraceId:-},%X{X-B3-SpanId:-}] %highlight(%-5level) %msg%n
            </Pattern>
        </layout>
        <addresses>${rabbitMQHost:-localhost}:5672</addresses>
        <generateId>true</generateId>
        <charset>UTF-8</charset>
        <durable>true</durable>
        <declareExchange>true</declareExchange>
        <deliveryMode>PERSISTENT</deliveryMode>
        <username>${rmq.user}</username>
        <password>${rmq.pass}</password>
</appender>
<root level="INFO">
    <appender-ref ref="CONSOLE" />
</root>
</configuration>